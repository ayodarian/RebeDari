# Supabase Configuration
# Get these values from your Supabase dashboard
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Firebase (añade estas variables en tu .env). No subas tu .env al repositorio.
# Obtén estas claves desde la consola de Firebase -> Configuración del proyecto
EXPO_FIREBASE_API_KEY=your_api_key_here
EXPO_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_FIREBASE_PROJECT_ID=your_project_id_here
EXPO_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_FIREBASE_APP_ID=your_app_id_here
EXPO_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
