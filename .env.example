# InsForge Configuration
# Get these values from your InsForge dashboard
# https://yc4iyiwy.us-west.insforge.app/dashboard
EXPO_PUBLIC_INSFORGE_URL=https://your-project.insforge.app
EXPO_PUBLIC_INSFORGE_ANON_KEY=your-anon-key

# Google OAuth (Expo Go)
# Create at: https://console.cloud.google.com/apis/credentials
# Use type "Web application" and add authorized redirect URIs:
#   exp://127.0.0.1:8081/--/
#   https://auth.expo.io/@your-username/your-app-slug
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
