{
  "expo": {
    "name": "RebeDari",
    "slug": "RebeDari",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "rebedari",
    "splash": {
      "image": "./assets/splash-icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B9D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rebedari.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rebedari.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c6a1210-1bd6-4506-a28e-e7310a240f15"
      }
    }
  }
}
